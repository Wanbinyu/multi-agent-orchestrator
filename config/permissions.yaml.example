# Copy to config/permissions.yaml for user-wide rules, or to
# <project>/.mao/permissions.yaml for project-scoped rules.
rules:
  - action: deny
    tool: run_command
    pattern: "rm *"
    justification: "禁止递归或批量删除；请改用精确文件操作"
    match:
      - "rm -rf build"
    not_match:
      - "python -m pytest tests"
  - action: ask
    tool: write_file
    pattern: "**/*.py"
    justification: "Python 源码修改需要确认"
  - action: allow
    tool: run_command
    pattern: "python -m pytest *"
    justification: "允许项目测试"
    match:
      - "python -m pytest tests"
    not_match:
      - "python -m pip install pytest"
